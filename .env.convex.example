# Convex Backend Configuration

# Get this from: npx convex dashboard
CONVEX_DEPLOYMENT_URL=https://your-project-name.convex.cloud

# Optional: Force SQLite backend instead of Convex
# CONVEX_DISABLED=true

# OpenAI API Key (for embeddings)
OPENAI_API_KEY=your-openai-api-key

# Gemini API Key (alternative)
# GOOGLE_API_KEY=your-gemini-api-key

# Embedding Provider: openai, gemini, local, auto
EMBEDDING_PROVIDER=openai

# Embedding Model
EMBEDDING_MODEL=text-embedding-3-small
