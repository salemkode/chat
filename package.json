{
  "name": "chat",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=web",
    "dev:scan": "turbo run dev:scan --filter=web",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=web",
    "start": "turbo run start --filter=web",
    "preview": "turbo run preview --filter=web",
    "typecheck": "oxlint --type-check",
    "typecheck:web": "turbo run typecheck --filter=web",
    "typecheck:convex": "tsc -p convex/tsconfig.json --noEmit",
    "test": "turbo run test --filter=web",
    "lint": "oxlint .",
    "lint:loc": "node scripts/lint-loc.mjs",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "check": "bun run lint && bun run format:check",
    "knip": "knip",
    "mobile:dev": "bun --filter mobile run dev",
    "ios": "bun --filter mobile run ios",
    "android": "bun --filter mobile run android",
    "mobile:typecheck": "bun --filter mobile run typecheck"
  },
  "dependencies": {
    "convex": "^1.34.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.9",
    "knip": "^5.81.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.42.0",
    "typescript": "^5.9.3",
    "turbo": "^2.5.8"
  }
}
