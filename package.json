{
  "name": "chat",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "docs"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo run dev --filter=!mobile",
    "dev:all": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:mobile": "pnpm --filter mobile dev",
    "dev:ios": "pnpm run ios",
    "dev:scan": "turbo run dev:scan --filter=web",
    "dev:sandbox-server": "cd apps/sandbox-server && pnpm run dev",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=web",
    "start": "turbo run start --filter=web",
    "start:sandbox-server": "cd apps/sandbox-server && pnpm run start",
    "preview": "turbo run preview --filter=web",
    "typecheck": "turbo run typecheck",
    "typecheck:web": "turbo run typecheck --filter=web",
    "typecheck:convex": "tsc -p packages/backend/convex/tsconfig.json --noEmit",
    "test": "turbo run test --filter=web",
    "lint": "oxlint .",
    "lint:mobile": "cd apps/mobile && pnpm run lint",
    "lint:loc": "node scripts/lint-loc.mjs",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "check": "pnpm run lint && pnpm run format:check",
    "fix": "pnpm run lint:fix && pnpm run format",
    "typecheck:all": "pnpm run typecheck:convex && pnpm run typecheck",
    "deploy:web:cloudflare": "cd apps/web && pnpm run build && pnpm run deploy:cloudflare",
    "knip": "knip",
    "mobile:dev": "cd apps/mobile && pnpm start",
    "ios": "cd apps/mobile && pnpm run ios",
    "android": "cd apps/mobile && pnpm run android",
    "mobile:typecheck": "cd apps/mobile && pnpm run typecheck",
    "docs:dev": "cd docs && pnpm run dev",
    "docs:build": "cd docs && pnpm run build",
    "docs:preview": "cd docs && pnpm run preview",
    "docs:deploy:cloudflare": "cd docs && pnpm run deploy:cloudflare",
    "postinstall": "node scripts/ensure-react-native-worklets-dir.mjs",
    "ship": "node scripts/ship.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "knip": "^5.88.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.42.0",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3",
    "vitest": "^3.0.5"
  },
  "packageManager": "pnpm@10.6.5",
  "overrides": {
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native-worklets": "0.8.1",
    "react-native-reanimated": "4.3.1",
    "@expo/dom-webview": "55.0.3"
  }
}
