{
  "cli": {
    "version": ">= 18.0.4",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "cache": {
        "disabled": true
      },
      "env": {
        "EXPO_NO_DOTENV": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "cache": {
        "disabled": true
      },
      "env": {
        "EXPO_NO_DOTENV": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "autoIncrement": true
      },
      "cache": {
        "disabled": false
      },
      "env": {
        "EXPO_NO_DOTENV": "1"
      },
      "config": {
        "skipNativeBuild": false
      },
      "node": "20"
    }
  },
  "submit": {
    "production": {}
  }
}
