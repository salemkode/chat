{
  "cli": {
    "version": ">= 18.0.4",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "environment": "development",
      "bun": "1.3.9",
      "developmentClient": true,
      "distribution": "internal",
      "cache": {
        "disabled": true
      },
      "env": {
        "EXPO_NO_DOTENV": "1"
      }
    },
    "preview": {
      "environment": "preview",
      "bun": "1.3.9",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "cache": {
        "disabled": true
      },
      "env": {
        "EXPO_NO_DOTENV": "1"
      }
    },
    "production": {
      "environment": "production",
      "bun": "1.3.9",
      "autoIncrement": true,
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "autoIncrement": true
      },
      "cache": {
        "disabled": false
      },
      "env": {
        "EXPO_NO_DOTENV": "1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
