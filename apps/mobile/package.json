{
  "name": "mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "dev:client": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo prebuild --clean && expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "build:development:android": "eas build --platform android --profile development",
    "build:development:ios": "eas build --platform ios --profile development",
    "build:development:ios-simulator": "eas build --platform ios --profile development-simulator",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@chat/shared": "workspace:*",
    "@clerk/expo": "^3.1.4",
    "@convex-dev/agent": "^0.6.1",
    "@expo-google-fonts/inter": "^0.4.2",
    "@lodev09/react-native-true-sheet": "^3.9.9",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-navigation/drawer": "^7.9.5",
    "@shopify/flash-list": "2.0.2",
    "convex": "^1.34.0",
    "expo": "~55.0.8",
    "expo-apple-authentication": "~8.0.8",
    "expo-auth-session": "~55.0.9",
    "expo-constants": "~55.0.9",
    "expo-dev-client": "~55.0.18",
    "expo-document-picker": "^55.0.9",
    "expo-font": "~55.0.4",
    "expo-image-manipulator": "^55.0.11",
    "expo-image-picker": "^55.0.13",
    "expo-linking": "~55.0.8",
    "expo-router": "^55.0.7",
    "expo-secure-store": "^55.0.9",
    "expo-splash-screen": "~55.0.12",
    "expo-sqlite": "^55.0.11",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "~55.0.10",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-enriched-markdown": "^0.4.1",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-reanimated": "^4.2.3",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-worklets": "^0.8.1",
    "tailwindcss": "^4.1.18",
    "uniwind": "^1.6.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "typescript": "~5.9.2"
  }
